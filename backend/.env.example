ENVIRONMENT=development
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
USE_MOCK_LLM=true

# SQLite database file (created automatically under backend/data/)
DATABASE_URL=sqlite:///./data/game.db

# OpenAI / LangChain (set USE_MOCK_LLM=false when configured)
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-word-battle

# Admin credentials are NOT in this public template.
# Keep ADMIN_EMAIL, ADMIN_PASSWORD, JWT_SECRET in backend/.env on your machine only.
# See docs/admin-local-only.md
